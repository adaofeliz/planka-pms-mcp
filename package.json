{
  "name": "@adaofeliz/planka-pms-mcp",
  "version": "0.1.3",
  "description": "GTD-inspired productivity system for AI agents — inbox capture, triage, scheduling, Pomodoro execution, and archival via Planka",
  "type": "module",
  "bin": {
    "planka-pms-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "config"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/adaofeliz/planka-pms-mcp.git"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess \"node dist/index.js --http --port=3000\"",
    "test": "vitest run",
    "test:live": "PLANKA_LIVE_TESTS=1 vitest run tests/live",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "planka",
    "project-management",
    "ai"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^17.4.1",
    "yaml": "^2.8.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.4"
  }
}
